# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# PostgreSQL (recommended for production)
DATABASE_URL="postgresql://user:password@localhost:5432/migrantcopilot"

# For quick local demo, you can use a free Supabase Postgres URL:
# DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# ─────────────────────────────────────────────
# AUTH (NextAuth)
# ─────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"

# ─────────────────────────────────────────────
# STRIPE (optional for demo — UI mocks payment)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRICE_ID_MONTHLY="price_..."

# ─────────────────────────────────────────────
# RESEND (optional for demo — emails are skipped)
# ─────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@migrantcopilot.es"

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"

# Vercel Cron secret (for weekly reminder emails)
CRON_SECRET="your-cron-secret-here"
